# ── PitchIQ Environment Configuration ────────────────────────────────────────
# Loaded automatically by the API, dashboard, and training scripts.
# NEVER commit a filled .env with real credentials to Git.

# ── API Keys ──────────────────────────────────────────────────────────────────
# RapidAPI key for API-Football (free tier: 100 req/day)
# Get one at: rapidapi.com → search "API-Football" → Subscribe to Basic plan
# Leave blank to use offline snapshot data (fully functional without it)
RAPIDAPI_KEY=
API_FOOTBALL_KEY=

# ── MLflow ────────────────────────────────────────────────────────────────────
# "mlruns"              → local file-based tracking, no server needed
# "http://localhost:5000" → when running `make docker-up`
# "https://dagshub.com/user/repo.mlflow" → remote team tracking
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=pitchiq_training
ENABLE_MLFLOW=1

# MLflow remote auth (leave blank for local tracking)
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# ── Model & Feature Paths ─────────────────────────────────────────────────────
MODEL_PATH=models/ensemble_v1.pkl
FEATURES_PATH=data/features/features_v2.parquet
DUCKDB_PATH=data/processed/matches.duckdb
FEATURE_STORE_TTL_S=600

# ── API Service ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Use http://api:8000 inside Docker (docker compose up)
# Use http://localhost:8000 for local dev
API_URL=http://localhost:8000
PITCHIQ_API_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=8501
DASHBOARD_HOST=0.0.0.0

# ── Training ──────────────────────────────────────────────────────────────────
PITCHIQ_TRAIN_BASELINES=0
PITCHIQ_VAL_FRAC=0.2

# ── DVC Remote (uncomment one) ────────────────────────────────────────────────
# DVC_REMOTE_URL=gdrive://your_gdrive_folder_id
# DVC_REMOTE_URL=s3://your-bucket/pitchiq-dvc

# ── Project ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
